generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum PaymentMethod {
  SINPE
  CASH
}

enum PaymentStatus {
  PENDING
  EN_VALIDACION
  PROOF_RECEIVED
  PAID
  REJECTED
}

enum OrderStatus {
  NEW
  CONFIRMED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CustomRequestStatus {
  NEW
  REVIEWED
  QUOTED
  ACCEPTED
  REJECTED
}

enum PromotionType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum OrderAdjustmentType {
  REFUND
  DISCOUNT
}

model AdminUser {
  id             String              @id @default(cuid())
  email          String              @unique
  passwordHash   String
  name           String
  isActive       Boolean             @default(true)
  reviewedProofs SinpePaymentProof[] @relation("ProofReviewer")
  pushSubscriptions PushSubscription[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model PushSubscription {
  id        String    @id @default(cuid())
  adminId   String
  admin     AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)
  endpoint  String    @unique @db.VarChar(512)
  p256dh    String    @db.VarChar(255)
  auth      String    @db.VarChar(255)
  userAgent String?   @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([adminId])
}

model AdminNotification {
  id          String    @id @default(cuid())
  title       String
  body        String    @db.Text
  url         String    @default("/admin")
  tag         String    @default("admin-event")
  deliveredAt DateTime?
  attempts    Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([deliveredAt, createdAt])
}

model Category {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?     @db.Text
  isActive    Boolean     @default(true)
  sortOrder   Int         @default(0)
  products    Product[]
  promotions  Promotion[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Product {
  id                   String          @id @default(cuid())
  categoryId           String
  category             Category        @relation(fields: [categoryId], references: [id])
  name                 String
  slug                 String          @unique
  description          String          @db.Text
  imageUrl             String?         @db.Text
  imagePath            String?         @db.Text
  visibleIngredients   String?         @db.Text
  estimatedDelivery    String          @default("24 a 48 horas")
  isFeatured           Boolean         @default(false)
  priceFinal           Decimal         @db.Decimal(10, 2)
  isActive             Boolean         @default(true)
  isAvailable          Boolean         @default(true)
  stockQuantity        Int?
  suggestedPrice       Decimal?        @db.Decimal(10, 2)
  desiredMarginPercent Decimal?        @db.Decimal(5, 2)
  desiredProfitAmount  Decimal?        @db.Decimal(10, 2)
  recipe               Recipe?
  costBatches          ProductCostBatch[]
  images               ProductImage[]
  orderItems           OrderItem[]
  promotions           Promotion[]
  ratings              ProductRating[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@index([categoryId])
  @@index([isActive, isAvailable])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String   @db.Text
  path      String?  @db.Text
  alt       String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([isPrimary])
}

model Ingredient {
  id                   String               @id @default(cuid())
  name                 String
  unit                 String
  lastPurchasePrice    Decimal              @db.Decimal(10, 2)
  lastPurchaseQuantity Decimal              @db.Decimal(10, 3)
  costPerUnit          Decimal              @db.Decimal(10, 4)
  isActive             Boolean              @default(true)
  purchases            IngredientPurchase[]
  recipeIngredients    RecipeIngredient[]
  productionCostItems  ProductCostItem[]
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
}

model IngredientPurchase {
  id            String     @id @default(cuid())
  ingredientId  String
  ingredient    Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  purchasePrice Decimal    @db.Decimal(10, 2)
  quantity      Decimal    @db.Decimal(10, 3)
  unit          String
  costPerUnit   Decimal    @db.Decimal(10, 4)
  purchasedAt   DateTime   @default(now())
  notes         String?    @db.Text

  @@index([ingredientId])
}

model Recipe {
  id          String             @id @default(cuid())
  productId   String             @unique
  product     Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  notes       String?            @db.Text
  ingredients RecipeIngredient[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model RecipeIngredient {
  id                String     @id @default(cuid())
  recipeId          String
  recipe            Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredientId      String
  ingredient        Ingredient @relation(fields: [ingredientId], references: [id])
  quantity          Decimal    @db.Decimal(10, 3)
  unit              String
  costAtCalculation Decimal?   @db.Decimal(10, 4)

  @@index([recipeId])
  @@index([ingredientId])
}

model ProductCostBatch {
  id                   String            @id @default(cuid())
  productId            String
  product              Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  name                 String
  producedQuantity     Decimal           @db.Decimal(10, 2)
  totalCost            Decimal           @db.Decimal(10, 2)
  costPerUnit          Decimal           @db.Decimal(10, 2)
  desiredMarginPercent Decimal?          @db.Decimal(5, 2)
  desiredProfitAmount  Decimal?          @db.Decimal(10, 2)
  suggestedPrice       Decimal           @db.Decimal(10, 2)
  notes                String?           @db.Text
  items                ProductCostItem[]
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@index([productId])
  @@index([createdAt])
}

model ProductCostItem {
  id           String           @id @default(cuid())
  batchId      String
  batch        ProductCostBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  ingredientId String?
  ingredient   Ingredient?      @relation(fields: [ingredientId], references: [id], onDelete: SetNull)
  name         String
  quantity     Decimal?         @db.Decimal(10, 3)
  unit         String?
  totalCost    Decimal          @db.Decimal(10, 2)
  createdAt    DateTime         @default(now())

  @@index([batchId])
  @@index([ingredientId])
}

model Promotion {
  id         String        @id @default(cuid())
  name       String
  code       String?       @unique
  type       PromotionType
  value      Decimal       @db.Decimal(10, 2)
  startsAt   DateTime
  endsAt     DateTime
  isActive   Boolean       @default(true)
  productId  String?
  product    Product?      @relation(fields: [productId], references: [id])
  categoryId String?
  category   Category?     @relation(fields: [categoryId], references: [id])
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([isActive, startsAt, endsAt])
}

model Order {
  id            String             @id @default(cuid())
  orderNumber   String             @unique
  customerName  String
  customerPhone String
  customerEmail String?
  customerId    String?
  customer      CustomerUser?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  deliveryNotes String?            @db.Text
  subtotal      Decimal            @db.Decimal(10, 2)
  discountTotal Decimal            @default(0) @db.Decimal(10, 2)
  total         Decimal            @db.Decimal(10, 2)
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus      @default(PENDING)
  orderStatus   OrderStatus        @default(NEW)
  items         OrderItem[]
  sinpeProof    SinpePaymentProof?
  adjustments   OrderAdjustment[]
  customRequest CustomDessertRequest?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([createdAt])
  @@index([paymentStatus])
}

model OrderAdjustment {
  id        String              @id @default(cuid())
  orderId   String
  order     Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type      OrderAdjustmentType
  amount    Decimal             @db.Decimal(10, 2)
  reason    String              @db.Text
  createdAt DateTime            @default(now())

  @@index([orderId])
  @@index([type])
}

model SiteSettings {
  id                 String   @id
  heroImageUrl       String?  @db.Text
  heroImagePath      String?  @db.Text
  heroEyebrow        String   @default("Horneado por encargo")
  heroTitle          String   @default("Horno Dulce")
  heroDescription    String   @db.Text
  heroNotice         String   @db.Text
  refundPolicy       String   @db.Text
  updatedAt          DateTime @updatedAt
}

model OrderItem {
  id                String   @id @default(cuid())
  orderId           String
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId         String?
  product           Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName       String
  imageUrl          String?  @db.Text
  estimatedDelivery String?
  reviewCode        String?  @unique
  unitPrice         Decimal  @db.Decimal(10, 2)
  quantity          Int
  lineTotal         Decimal  @db.Decimal(10, 2)

  @@index([orderId])
  @@index([productId])
}

model ProductRating {
  id           String   @id @default(cuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItemId  String?  @unique
  reviewCode   String   @unique
  customerName String
  rating       Int      @default(5)
  comment      String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([productId])
}

model CustomerUser {
  id           String   @id @default(cuid())
  name         String   @unique
  passwordHash String
  orders       Order[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SinpePaymentProof {
  id              String     @id @default(cuid())
  orderId         String     @unique
  order           Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  holderName      String
  sinpeNumber     String
  expectedAmount  Decimal    @db.Decimal(10, 2)
  proofUrl        String?    @db.Text
  proofPath       String?    @db.Text
  uploadedAt      DateTime?
  sentByWhatsapp  Boolean    @default(false)
  whatsappSentAt  DateTime?
  reviewedAt      DateTime?
  reviewedById    String?
  reviewedBy      AdminUser? @relation("ProofReviewer", fields: [reviewedById], references: [id])
  rejectionReason String?    @db.Text
}

model Review {
  id           String       @id @default(cuid())
  customerName String?
  isAnonymous  Boolean      @default(false)
  rating       Int
  comment      String       @db.Text
  status       ReviewStatus @default(PENDING)
  approvedAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([status])
}

model CustomDessertRequest {
  id            String              @id @default(cuid())
  orderId       String?             @unique
  order         Order?              @relation(fields: [orderId], references: [id], onDelete: SetNull)
  customerName  String
  customerPhone String
  customerEmail String?
  description   String              @db.Text
  notes         String?             @db.Text
  servings      Int?
  desiredDate   DateTime?
  imageUrl      String?             @db.Text
  imagePath     String?             @db.Text
  status        CustomRequestStatus @default(NEW)
  adminNotes    String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([status])
}
